---
import { t, localePath, type Locale } from '../i18n/utils';
import { siteConfig } from '../content/site.config';

interface Props { locale?: Locale; }
const { locale = 'en' } = Astro.props;
---

<section class="relative h-screen w-full overflow-hidden">
  <!-- Poster layer: always behind the video, animates while video loads -->
  <div id="hero-poster" class="absolute inset-0 z-0" aria-hidden="true">
    <div
      class="absolute inset-0 bg-cover bg-center animate-hero-zoom"
      style={`background-image: url('${import.meta.env.BASE_URL.replace(/\/$/, '')}${siteConfig.heroPoster}');`}
    ></div>
  </div>

  <!-- Video layer: invisible until canplay fires, then cross-fades in -->
  <div class="absolute inset-0 z-0">
    <video
      id="hero-video"
      class="absolute inset-0 w-full h-full object-cover opacity-0"
      style="transition: opacity 1.2s ease;"
      autoplay
      muted
      loop
      playsinline
      preload="auto"
      poster={`${import.meta.env.BASE_URL.replace(/\/$/, '')}${siteConfig.heroPoster}`}
      data-src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}${siteConfig.heroVideo}`}
      data-src-mobile={`${import.meta.env.BASE_URL.replace(/\/$/, '')}${siteConfig.heroVideoMobile}`}
    >
    </video>
    <!-- Dark overlay gradient — bottom-heavy for text readability -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-black/50 to-transparent" aria-hidden="true"></div>
  </div>

  <!-- Content overlay — bottom-left aligned like reference -->
  <div class="relative z-10 h-full flex flex-col justify-end px-6 lg:px-12 xl:px-20 pb-16 md:pb-20 lg:pb-24">
    <div class="max-w-4xl">
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-[5.5rem] font-display font-bold leading-[0.92] tracking-tight-display text-white mb-4 md:mb-6 animate-fade-in-up" style="animation-delay: 0.2s;">
        {t(locale, 'hero.heading')}
      </h1>
      <p class="text-lg md:text-xl lg:text-2xl text-white/80 font-display italic mb-8 md:mb-10 animate-fade-in-up" style="animation-delay: 0.4s;">
        {t(locale, 'hero.title')}
      </p>
      <div class="animate-fade-in-up" style="animation-delay: 0.6s;">
        <a
          href={localePath(locale, '/contact')}
          class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full border border-white/30 text-white text-sm uppercase tracking-display font-medium hover:bg-white hover:text-black transition-all duration-300"
        >
          {t(locale, 'cta.button')}
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 animate-fade-in" style="animation-delay: 1.2s;">
    <div class="flex flex-col items-center gap-2">
      <div class="w-px h-10 bg-gradient-to-b from-white/50 to-transparent"></div>
    </div>
  </div>
</section>

<script>
  const video = document.getElementById('hero-video') as HTMLVideoElement | null;
  const poster = document.getElementById('hero-poster');

  if (video) {
    const srcDesktop = video.dataset.src!;
    const srcMobile  = video.dataset.srcMobile!;

    /** Portrait-mobile breakpoint — matches CSS `md` boundary */
    const mobilePortrait = window.matchMedia('(max-width: 767px) and (orientation: portrait)');

    const fadeIn = () => {
      video.style.opacity = '1';
      if (poster) setTimeout(() => poster.remove(), 1400);
    };

    let currentSrc = '';

    function loadSource(src: string): void {
      if (src === currentSrc) return;
      currentSrc = src;

      const wasPlaying = !video!.paused;
      video!.style.opacity = '0';
      video!.src = src;
      video!.load();

      video!.addEventListener('playing', () => {
        video!.style.opacity = '1';
      }, { once: true });

      if (wasPlaying) video!.play().catch(() => {});
    }

    function pickSource(e: MediaQueryListEvent | MediaQueryList): void {
      loadSource(e.matches ? srcMobile : srcDesktop);
    }

    // Initial source selection (before any fade-in listener)
    pickSource(mobilePortrait);

    video.addEventListener('playing', fadeIn, { once: true });

    // Already playing (e.g. cached)
    if (!video.paused) fadeIn();

    // React to orientation / resize changes
    mobilePortrait.addEventListener('change', pickSource);
  }
</script>
