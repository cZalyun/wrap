---
import { t, type Locale } from '../i18n/utils';

interface Props { locale?: Locale; }
const { locale = 'en' } = Astro.props;
---

<section class="section-cream section-padding px-6 lg:px-8">
  <div class="mx-auto max-w-7xl reveal-on-scroll">
    <h2 class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-display font-bold italic leading-[0.9] mb-4">
      {t(locale, 'definition.word')}.
    </h2>
    <div class="mt-4 mb-2">
      <span class="text-xs uppercase tracking-[0.2em] opacity-50">[{t(locale, 'definition.type')}]</span>
    </div>
    <p class="text-sm opacity-50 mb-6 font-sans">{t(locale, 'definition.phonetic')}</p>
    <p class="text-base md:text-lg leading-relaxed max-w-2xl opacity-70">
      {t(locale, 'definition.meaning')}
    </p>
  </div>
</section>
