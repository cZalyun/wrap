---
import { siteConfig } from '../content/site.config';
import { t, type Locale } from '../i18n/utils';

interface Props { locale?: Locale; }
const { locale = 'en' } = Astro.props;
---

<section class="section-olive py-14 md:py-20 px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <p class="text-center text-xs uppercase tracking-[0.25em] opacity-60 mb-10 md:mb-14">{t(locale, 'trustedBy')}</p>
    <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12 lg:gap-16">
      {siteConfig.brands.map((brand) => (
        <span class="text-xs md:text-sm tracking-[0.2em] uppercase opacity-40 hover:opacity-80 transition-opacity duration-300 font-medium select-none">
          {brand}
        </span>
      ))}
    </div>
  </div>
</section>
