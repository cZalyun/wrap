---
import { t, type Locale } from '../i18n/utils';
interface Props { locale?: Locale; }
const { locale = 'en' } = Astro.props;
---

<button
  type="button"
  aria-label={t(locale, 'theme.dark')}
  class="theme-toggle-btn relative w-9 h-9 flex items-center justify-center rounded-full border border-white/20 hover:border-white/40 transition-colors duration-200 cursor-pointer text-white"
>
  <!-- Sun icon (shown in dark mode) -->
  <svg class="w-4 h-4 sun-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <circle cx="12" cy="12" r="5" />
    <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg class="w-4 h-4 moon-icon hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
  </svg>
</button>

