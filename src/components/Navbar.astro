---
import { siteConfig } from '../content/site.config';
import { t, localePath, type Locale } from '../i18n/utils';
import ThemeToggle from './ThemeToggle.astro';
import LanguageToggle from './LanguageToggle.astro';

interface Props { locale?: Locale; }
const { locale = 'en' } = Astro.props;
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 text-white">
  <nav class="mx-auto max-w-7xl px-6 lg:px-8 flex items-center justify-between h-16 lg:h-20">
    <!-- Logo -->
    <a href={localePath(locale, '/')} class="relative z-50 text-lg font-display font-bold italic transition-opacity hover:opacity-70 text-white">
      {siteConfig.brand}
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-8">
      {siteConfig.navigation.map((item) => (
        <a
          href={localePath(locale, item.path)}
          class="text-sm tracking-[0.1em] uppercase transition-opacity hover:opacity-70 text-white"
        >
          {t(locale, item.key)}
        </a>
      ))}
      <div class="flex items-center gap-3 ml-4">
        <LanguageToggle locale={locale} />
        <ThemeToggle locale={locale} />
      </div>
    </div>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      type="button"
      aria-label="Toggle menu"
      aria-expanded="false"
      class="relative z-50 md:hidden w-10 h-10 cursor-pointer text-white"
    >
      <span class="absolute left-2 top-[16px] block w-6 h-[1.5px] bg-white transition-all duration-300 origin-center" id="menu-line-1"></span>
      <span class="absolute left-2 top-[23px] block w-6 h-[1.5px] bg-white transition-all duration-300 origin-center" id="menu-line-2"></span>
    </button>
  </nav>
</header>

<!-- Mobile menu — separate from header for proper full-screen overlay -->
<div id="mobile-menu" class="fixed inset-0 z-40 md:hidden pointer-events-none opacity-0 transition-opacity duration-300" style="background-color: #0A0A0B;">
  <div class="flex flex-col items-center justify-center h-full gap-7 px-6">
    {siteConfig.navigation.map((item, i) => (
      <a
        href={localePath(locale, item.path)}
        class="mobile-nav-link text-3xl sm:text-4xl font-display text-white tracking-[0.04em] uppercase transition-all duration-300 opacity-0 translate-y-4"
        style={`transition-delay: ${i * 60 + 100}ms;`}
      >
        {t(locale, item.key)}
      </a>
    ))}
    <div class="flex items-center gap-5 mt-6 opacity-0 translate-y-4 mobile-nav-link transition-all duration-300" style={`transition-delay: ${siteConfig.navigation.length * 60 + 100}ms;`}>
      <LanguageToggle locale={locale} />
      <ThemeToggle locale={locale} />
    </div>
  </div>
</div>

<script is:inline>
(function() {
  document.addEventListener('DOMContentLoaded', function() {
    var navbar = document.getElementById('navbar');
    var btn = document.getElementById('mobile-menu-btn');
    var menu = document.getElementById('mobile-menu');
    var line1 = document.getElementById('menu-line-1');
    var line2 = document.getElementById('menu-line-2');
    var isOpen = false;

    // Scroll effect — blur navbar on scroll
    window.addEventListener('scroll', function() {
      if (!navbar || isOpen) return;
      if (window.scrollY > 60) {
        navbar.style.backdropFilter = 'blur(12px)';
        navbar.style.webkitBackdropFilter = 'blur(12px)';
        navbar.style.backgroundColor = 'rgba(10,10,11,0.6)';
      } else {
        navbar.style.backdropFilter = 'none';
        navbar.style.webkitBackdropFilter = 'none';
        navbar.style.backgroundColor = 'transparent';
      }
    });

    if (!btn || !menu) return;

    function openMenu() {
      isOpen = true;
      btn.setAttribute('aria-expanded', 'true');
      menu.style.pointerEvents = 'auto';
      menu.style.opacity = '1';
      document.body.style.overflow = 'hidden';
      // Animate hamburger to X
      line1.style.transform = 'translateY(3.5px) rotate(45deg)';
      line2.style.transform = 'translateY(-3.5px) rotate(-45deg)';
      // Animate nav links in
      menu.querySelectorAll('.mobile-nav-link').forEach(function(el) {
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      });
    }

    function closeMenu() {
      isOpen = false;
      btn.setAttribute('aria-expanded', 'false');
      // Animate nav links out first
      menu.querySelectorAll('.mobile-nav-link').forEach(function(el) {
        el.style.opacity = '0';
        el.style.transform = 'translateY(16px)';
      });
      // Then fade overlay
      setTimeout(function() {
        menu.style.opacity = '0';
        menu.style.pointerEvents = 'none';
        document.body.style.overflow = '';
      }, 200);
      // Reset hamburger
      line1.style.transform = '';
      line2.style.transform = '';
    }

    btn.addEventListener('click', function() {
      if (isOpen) closeMenu(); else openMenu();
    });

    // Close on link click
    menu.querySelectorAll('a').forEach(function(link) {
      link.addEventListener('click', closeMenu);
    });

    // Close on Escape
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && isOpen) closeMenu();
    });
  });
})();
</script>
