---
import { localePath, type Locale } from '../i18n/utils';
import type { WorkItem } from '../content/site.config';
import { getLocalizedString } from '../content/site.config';
import { t } from '../i18n/utils';

interface Props {
  work: WorkItem;
  locale: Locale;
  index: number;
  featured?: boolean;
}

const { work, locale, index, featured = false } = Astro.props;
---

<div class="reveal-on-scroll" style={`animation-delay: ${index * 0.15}s`}>
  <a
    href={localePath(locale, `/work/${work.slug}`)}
    class="group block relative overflow-hidden rounded-xl"
  >
    <!-- Large cinematic aspect ratio like video embed -->
    <div class:list={[
      'relative overflow-hidden border theme-border',
      featured ? 'aspect-[16/9]' : 'aspect-[16/10]',
      'rounded-xl'
    ]}>
      <img
        src={`/wrap${work.coverImage}`}
        alt={getLocalizedString(work.title, locale)}
        width="1280"
        height="720"
        loading={index < 2 ? 'eager' : 'lazy'}
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      />
      <!-- Gradient overlay -->
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-500"></div>

      <!-- Play button overlay -->
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="w-16 h-16 md:w-20 md:h-20 rounded-full border-2 border-white/30 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500 group-hover:scale-110 backdrop-blur-sm bg-white/5">
          <svg class="w-6 h-6 md:w-8 md:h-8 text-white ml-1" fill="currentColor" viewBox="0 0 24 24">
            <path d="M8 5v14l11-7z"/>
          </svg>
        </div>
      </div>

      <!-- Bottom info overlay -->
      <div class="absolute bottom-0 left-0 right-0 p-5 md:p-8">
        <div class="flex items-end justify-between gap-4">
          <div>
            <span class="text-xs uppercase tracking-[0.2em] text-white/50 mb-2 block">
              {getLocalizedString(work.category, locale)}
            </span>
            <h3 class:list={[
              'font-display font-semibold text-white leading-tight',
              featured ? 'text-2xl md:text-3xl lg:text-4xl' : 'text-xl md:text-2xl'
            ]}>
              {getLocalizedString(work.title, locale)}
            </h3>
            <p class="text-sm text-white/60 mt-2 max-w-md hidden md:block">
              {getLocalizedString(work.subtitle, locale)}
            </p>
          </div>
          <span class="text-xs text-white/40 uppercase tracking-display flex-shrink-0 hidden sm:block">
            {work.year}
          </span>
        </div>
      </div>
    </div>
  </a>
</div>
