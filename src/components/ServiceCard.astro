---
interface Props {
  title: string;
  subtitle: string;
  items: string[];
  index: number;
}

const { title, subtitle, items, index } = Astro.props;
const num = String(index + 1).padStart(2, '0');
---

<div class="reveal-on-scroll border-t border-current/10 pt-8" style={`animation-delay: ${index * 0.15}s`}>
  <div class="flex items-baseline gap-4 mb-2">
    <span class="text-sm opacity-40 font-sans">{num}</span>
    <h3 class="text-2xl md:text-3xl lg:text-4xl font-display font-bold uppercase">{title}</h3>
  </div>
  <p class="text-xs md:text-sm uppercase tracking-[0.15em] font-semibold opacity-70 mb-5 ml-10">{subtitle}</p>
  <ul class="space-y-1.5 ml-10">
    {items.map((item) => (
      <li class="flex items-start gap-2.5 text-sm opacity-60">
        <span class="mt-1.5 w-1 h-1 rounded-full bg-current opacity-40 flex-shrink-0" aria-hidden="true"></span>
        {item}
      </li>
    ))}
  </ul>
</div>
