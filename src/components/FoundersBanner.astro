---
import { t, type Locale } from '../i18n/utils';

interface Props { locale?: Locale; }
const { locale = 'en' } = Astro.props;
---

<section class="relative h-[60vh] md:h-[70vh] w-full overflow-hidden">
  <div class="absolute inset-0">
    <img
      src="/wrap/images/hero-poster.svg"
      alt=""
      class="w-full h-full object-cover"
      aria-hidden="true"
    />
    <div class="absolute inset-0 bg-black/50"></div>
  </div>
  <div class="relative z-10 h-full flex items-center justify-center px-6 text-center">
    <h2 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-display leading-[1.05] text-white max-w-4xl">
      {locale === 'en'
        ? <>Founded by <em class="italic">filmmakers</em>.<br/>Driven by <em class="italic">story</em>.</>
        : <>Filmes alkotók <em class="italic">alapították</em>.<br/>A <em class="italic">történet</em> hajtja.</>
      }
    </h2>
  </div>
</section>
