---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { href, variant = 'primary', size = 'md', class: className = '' } = Astro.props;
const Tag = href ? 'a' : 'button';

const variants = {
  primary: 'bg-accent text-bg hover:bg-accent-hover',
  secondary: 'border theme-border theme-border-hover',
  ghost: 'hover:opacity-70',
};

const sizes = {
  sm: 'px-4 py-2 text-xs',
  md: 'px-6 py-3 text-sm',
  lg: 'px-8 py-4 text-sm',
};
---

<Tag
  href={href}
  class:list={[
    'inline-flex items-center justify-center gap-2 rounded-full font-medium uppercase tracking-display transition-all duration-300 cursor-pointer',
    variants[variant],
    sizes[size],
    className,
  ]}
>
  <slot />
</Tag>
