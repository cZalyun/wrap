---
import { t, switchLocalePath, type Locale, locales, defaultLocale } from '../i18n/utils';

interface Props { locale?: Locale; }
const { locale = 'en' } = Astro.props;

const targetLocale = locale === 'en' ? 'hu' : 'en';
const switchUrl = switchLocalePath(Astro.url, targetLocale);
---

<a
  href={switchUrl}
  aria-label={t(locale, 'lang.switchTo')}
  class="flex items-center gap-1.5 px-2.5 py-1.5 text-xs font-medium uppercase tracking-display rounded-full border border-white/20 hover:border-white/40 transition-colors duration-200 text-white"
>
  <span class="opacity-60">{locale.toUpperCase()}</span>
  <span class="opacity-30">/</span>
  <span>{targetLocale.toUpperCase()}</span>
</a>
