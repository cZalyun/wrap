---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import type { Locale } from '../i18n/utils';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
  locale?: Locale;
  type?: string;
  noindex?: boolean;
}

const { title, description, ogImage, canonicalUrl, locale = 'en', type = 'website', noindex = false } = Astro.props;
---

<!DOCTYPE html>
<html lang={locale} class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <!-- Preload fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
    rel="stylesheet"
  />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />

  <SEOHead
    title={title}
    description={description}
    ogImage={ogImage}
    canonicalUrl={canonicalUrl}
    locale={locale}
    type={type}
    noindex={noindex}
  />

  <!-- Theme init (prevent flash) -->
  <script is:inline>
    (function() {
      var theme = localStorage.getItem('theme');
      if (!theme) {
        theme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      }
      document.documentElement.classList.add(theme);
      document.documentElement.classList.remove(theme === 'light' ? 'dark' : 'light');
    })();
  </script>

  <!-- SPA fallback restore (for GitHub Pages 404 redirect) -->
  <script is:inline>
    (function() {
      var redirect = sessionStorage.getItem('spa-redirect');
      if (redirect) {
        sessionStorage.removeItem('spa-redirect');
        var url = new URL(redirect, window.location.origin);
        if (url.pathname !== window.location.pathname) {
          window.history.replaceState(null, '', redirect);
        }
      }
    })();
  </script>
</head>
<body class="min-h-screen flex flex-col overflow-x-hidden">
  <div class="grain" aria-hidden="true"></div>
  <Navbar locale={locale} />
  <main class="flex-1">
    <slot />
  </main>
  <Footer locale={locale} />

  <script>
    function applyTheme(t: string) {
      const R = document.documentElement;
      R.classList.toggle('light', t === 'light');
      R.classList.toggle('dark', t !== 'light');
      document.querySelectorAll('.sun-icon').forEach((e) => e.classList.toggle('hidden', t === 'light'));
      document.querySelectorAll('.moon-icon').forEach((e) => e.classList.toggle('hidden', t !== 'light'));
    }

    applyTheme(document.documentElement.classList.contains('light') ? 'light' : 'dark');

    document.querySelectorAll('.theme-toggle-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const next = document.documentElement.classList.contains('light') ? 'dark' : 'light';
        localStorage.setItem('theme', next);
        applyTheme(next);
      });
    });
  </script>
</body>
</html>
