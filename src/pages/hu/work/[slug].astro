---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section from '../../../components/Section.astro';
import Button from '../../../components/Button.astro';
import CTASection from '../../../components/CTASection.astro';
import RevealOnScroll from '../../../components/RevealOnScroll.astro';
import { siteConfig, getLocalizedString, type WorkItem } from '../../../content/site.config';
import { t, localePath } from '../../../i18n/utils';

const locale = 'hu';

export function getStaticPaths() {
  return siteConfig.work.map((work) => ({
    params: { slug: work.slug },
    props: { work },
  }));
}

interface Props { work: WorkItem; }
const { work } = Astro.props;
---

<BaseLayout
  title={getLocalizedString(work.title, locale)}
  description={getLocalizedString(work.subtitle, locale)}
  locale={locale}
>
  <div class="pt-20"></div>
  <Section>
    <div class="mb-8">
      <Button href={localePath(locale, '/work')} variant="ghost" size="sm">
        {t(locale, 'work.backToWork')}
      </Button>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 reveal-on-scroll">
      <div>
        <p class="text-xs uppercase tracking-display opacity-40 mb-3">
          {getLocalizedString(work.category, locale)}
        </p>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-display font-semibold mb-4">
          {getLocalizedString(work.title, locale)}
        </h1>
        <p class="text-base md:text-lg opacity-50 mb-8 leading-relaxed">
          {getLocalizedString(work.subtitle, locale)}
        </p>

        <div class="grid grid-cols-2 gap-6 mb-8">
          <div>
            <p class="text-xs uppercase tracking-display opacity-40 mb-1">{t(locale, 'work.role')}</p>
            <p class="text-sm">{getLocalizedString(work.role, locale)}</p>
          </div>
          <div>
            <p class="text-xs uppercase tracking-display opacity-40 mb-1">{t(locale, 'work.year')}</p>
            <p class="text-sm">{work.year}</p>
          </div>
        </div>

        {work.metrics && work.metrics.length > 0 && (
          <div class="grid grid-cols-2 gap-6 py-6 border-t theme-border">
            {work.metrics.map((metric) => (
              <div>
                <p class="text-2xl md:text-3xl font-display font-semibold text-accent">{metric.value}</p>
                <p class="text-xs uppercase tracking-display opacity-40 mt-1">{getLocalizedString(metric.label, locale)}</p>
              </div>
            ))}
          </div>
        )}

        <p class="text-sm opacity-70 leading-relaxed mt-8">
          {getLocalizedString(work.description, locale)}
        </p>
      </div>

      <div class="relative aspect-[4/3] rounded-xl overflow-hidden border theme-border">
        <img
          src={`/wrap${work.coverImage}`}
          alt={getLocalizedString(work.title, locale)}
          width="800"
          height="600"
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </Section>
  <CTASection locale={locale} />
  <RevealOnScroll />
</BaseLayout>
